#!/usr/bin/env python3

"""
Command line utility for reading ROV Hand Controller from joystick device and publishing to Keelson/Zenoh.

Reads controller data from Linux joystick device (/dev/input/js0), captures axes and button events,
and publishes to appropriate Keelson subjects on the Zenoh bus.

Controller is accessed via standard Linux joystick interface using HID protocol.
This provides much faster and more reliable button/axis detection than the serial interface.

Publishes to Keelson subjects:
- joystick_x (TimestampedInt) - X axis value (-32768 to 32767)
- joystick_y (TimestampedInt) - Y axis value (-32768 to 32767)
- joystick_rz (TimestampedInt) - Rotation Z axis value (-32768 to 32767)
- joystick_z (TimestampedInt) - Z axis/throttle value (-32768 to 32767)
- {function_name} (TimestampedInt) - 1 when pressed, 0 when released for mapped buttons
  e.g. arm, disarm, mount_tilt_up, lights1_brighter, shift, mode_manual, ...
  Shift + button publishes to alternate subject e.g. trim_roll_inc, input_hold_set, ...
- button_pressed (TimestampedInt) - Button number for unmapped buttons when pressed
- button_released (TimestampedInt) - Button number for unmapped buttons when released
"""

import sys
import json
import logging
import time
import struct
import signal
from datetime import datetime, timezone
from typing import Dict, Any
from pathlib import Path

import zenoh
import keelson
from keelson.payloads.Primitives_pb2 import TimestampedInt, TimestampedBytes

from terminal_inputs import terminal_inputs

# Global state
PUBLISHERS: Dict[tuple, Any] = {}  # Cache for lazy publisher creation
shutdown_requested = False  # Flag for graceful shutdown
shift_active = False  # Tracks whether the Shift modifier button is held

# Joystick event format (from linux/joystick.h)
JS_EVENT_BUTTON = 0x01  # Button pressed/released
JS_EVENT_AXIS = 0x02    # Joystick moved
JS_EVENT_INIT = 0x80    # Initial state

# Axis mapping for ROV controller
AXIS_MAP = {
    0: 'joystick_x',   # X axis
    1: 'joystick_y',   # Y axis
    2: 'joystick_z',   # Z axis (throttle)
    3: 'joystick_rz',  # Rz axis (rotation/twist)
}

# Primary button function mapping (0-indexed Linux joystick button numbers)
# Physical button N (1-indexed from manual) = Linux button N-1 (0-indexed)
BUTTON_MAP = {
    0:  'servo_3_min_momentary',  # Button 1: Open Gripper
    1:  'servo_3_max_momentary',  # Button 2: Close Gripper
    2:  'lights1_brighter',       # Button 3 (CCW): Lights Brighter
    3:  'lights1_dimmer',         # Button 4 (CW): Lights Dimmer
    4:  'gain_inc',               # Button 5 (CCW): Increase Gain
    5:  'gain_dec',               # Button 6 (CW): Decrease Gain
    6:  'mount_tilt_up',          # Button 7: Camera Tilt Up
    7:  'mount_tilt_down',        # Button 8: Camera Tilt Down
    8:  'shift',                  # Button 9: Shift modifier
    9:  'mode_manual',            # Button 10: Manual Flight Mode
    10: 'mode_stabilize',         # Button 11: Stabilize Flight Mode
    11: 'mode_depth_hold',        # Button 12: Depth Hold Flight Mode
    12: 'mode_poshold',           # Button 13: Position Hold Flight Mode
    13: 'arm',                    # Button 14: Arm ROV
    14: 'disarm',                 # Button 15: Disarm ROV
    15: 'a',                      # Button 16: User-defined
    16: 'b',                      # Button 17: User-defined
    17: 'joystick_top_left',      # Button 18: User-defined
    18: 'joystick_top_right',     # Button 19: User-defined
    
    # Buttons 16-18 are user-defined, no default mapping
}

# Alternate (Shift + button) function mapping for dual-function buttons
BUTTON_SHIFT_MAP = {
    0: 'input_hold_set',          # Button 1 + Shift: Toggle Input Hold
    1: 'roll_pitch_toggle',       # Button 2 + Shift: Toggle Roll and Pitch
    2: 'trim_roll_inc',           # Button 3 + Shift (CCW): Trim Roll Right
    3: 'trim_roll_dec',           # Button 4 + Shift (CW): Trim Roll Left
    4: 'trim_pitch_inc',          # Button 5 + Shift (CCW): Trim Pitch Forward
    5: 'trim_pitch_dec',          # Button 6 + Shift (CW): Trim Pitch Backward
}

SHIFT_BUTTON = 8  # 0-indexed button number of the Shift modifier

logger = logging.getLogger("hcssrov2keelson")


def signal_handler(signum, frame):
    """Handle shutdown signals gracefully."""
    global shutdown_requested
    logger.info("Shutdown signal received")
    shutdown_requested = True


def get_or_create_publisher(
    session, realm: str, entity_id: str, subject: str, source_id: str
):
    """
    Get or create a Zenoh publisher for the specified subject.

    Publishers are cached globally to avoid recreating them for repeated publishes.
    """
    key = (realm, entity_id, subject, source_id)
    if key not in PUBLISHERS:
        key_expr = keelson.construct_pubsub_key(realm, entity_id, subject, source_id)
        PUBLISHERS[key] = session.declare_publisher(
            key_expr,
            congestion_control=zenoh.CongestionControl.DROP,
            priority=zenoh.Priority.DEFAULT,
        )
        logger.debug(f"Created publisher for {key_expr}")
    return PUBLISHERS[key]


def publish_data(
    session, realm: str, entity_id: str, subject: str, value: bytes, source_id: str
):
    """Publish data to a Keelson subject."""
    publisher = get_or_create_publisher(session, realm, entity_id, subject, source_id)
    publisher.put(value)


def enclose_from_int(value: int, timestamp_ns: int | None = None) -> bytes:
    """Create an enclosed TimestampedInt message."""
    if timestamp_ns is None:
        timestamp_ns = time.time_ns()
    
    payload = TimestampedInt()
    payload.timestamp.FromNanoseconds(timestamp_ns)
    payload.value = value
    return keelson.enclose(payload.SerializeToString())


def read_joystick_event(device_file):
    """
    Read a single joystick event from the device.
    
    Event format (8 bytes):
        - timestamp (4 bytes, unsigned int)
        - value (2 bytes, signed short)
        - type (1 byte, unsigned char)
        - number (1 byte, unsigned char)
    
    Returns:
        tuple: (timestamp, value, event_type, number) or None if no data
    """
    try:
        event_data = device_file.read(8)
        if len(event_data) < 8:
            return None
        
        # Unpack event: timestamp (I), value (h), type (B), number (B)
        timestamp, value, event_type, number = struct.unpack('IhBB', event_data)
        return (timestamp, value, event_type, number)
    except Exception as e:
        logger.debug(f"Error reading joystick event: {e}")
        return None


def handle_joystick_event(timestamp, value, event_type, number, session, args):
    """
    Handle a joystick event and publish to Keelson.
    
    Args:
        timestamp: Event timestamp from kernel (milliseconds)
        value: Event value (button: 0/1, axis: -32768 to 32767)
        event_type: JS_EVENT_BUTTON or JS_EVENT_AXIS (may include JS_EVENT_INIT flag)
        number: Button/axis number
        session: Zenoh session
        args: Command line arguments
    """
    timestamp_ns = time.time_ns()
    
    # Remove INIT flag to get actual event type
    event_type = event_type & ~JS_EVENT_INIT
    
    if event_type == JS_EVENT_BUTTON:
        global shift_active
        pressed = value == 1

        if number == SHIFT_BUTTON:
            shift_active = pressed
            subject = 'shift'
        elif shift_active and number in BUTTON_SHIFT_MAP:
            subject = BUTTON_SHIFT_MAP[number]
        elif number in BUTTON_MAP:
            subject = BUTTON_MAP[number]
        else:
            # Unmapped button: fallback to generic subjects with button number as value
            subject = 'button_pressed' if pressed else 'button_released'
            logger.info(f"Button {number} (unmapped) {'pressed' if pressed else 'released'}")
            publish_data(
                session, args.realm, args.entity_id, subject,
                enclose_from_int(number, timestamp_ns), args.source_id,
            )
            return

        logger.info(f"Button {number} ({subject}) {'pressed' if pressed else 'released'}")
        publish_data(
            session, args.realm, args.entity_id, subject,
            enclose_from_int(int(pressed), timestamp_ns), args.source_id,
        )
    
    elif event_type == JS_EVENT_AXIS:
        # Axis event - check if it's one we care about
        if number in AXIS_MAP:
            axis_name = AXIS_MAP[number]
            logger.debug(f"Axis {number} ({axis_name}): {value}")
            
            publish_data(
                session,
                args.realm,
                args.entity_id,
                axis_name,
                enclose_from_int(value, timestamp_ns),
                args.source_id,
            )
        else:
            logger.debug(f"Ignoring unmapped axis {number}: {value}")


def main():
    # Parse arguments
    args = terminal_inputs()
    
    # Setup logging
    logging.basicConfig(
        format="%(asctime)s %(levelname)s %(name)s %(message)s", level=args.log_level
    )
    logging.captureWarnings(True)

    # Setup signal handlers
    signal.signal(signal.SIGINT, signal_handler)
    signal.signal(signal.SIGTERM, signal_handler)

    # Configure Zenoh
    conf = zenoh.Config()
    if args.mode is not None:
        conf.insert_json5("mode", json.dumps(args.mode))
    if args.connect is not None:
        conf.insert_json5("connect/endpoints", json.dumps(args.connect))

    # Initialize Zenoh logging
    zenoh.init_log_from_env_or(logging.getLevelName(args.log_level))

    # Check if joystick device exists
    device_path = Path(args.device)
    if not device_path.exists():
        logger.error(f"Joystick device {args.device} not found!")
        logger.error("Available devices:")
        input_dir = Path("/dev/input")
        if input_dir.exists():
            for dev in sorted(input_dir.glob("js*")):
                logger.error(f"  {dev}")
        sys.exit(1)

    logger.info(f"Opening joystick device {args.device}...")
    try:
        # Open joystick device in binary read mode, non-blocking
        js_device = open(args.device, 'rb', buffering=0)
        logger.info(f"Opened joystick device {args.device}")
    except IOError as e:
        logger.error(f"Failed to open joystick device {args.device}: {e}")
        logger.error("Make sure you have permissions to read the device")
        logger.error("Try: sudo chmod a+r /dev/input/js*")
        sys.exit(1)

    logger.info("Opening Zenoh session...")
    with zenoh.open(conf) as session:
        logger.info(f"Connected to realm: {args.realm}, entity: {args.entity_id}")
        logger.info(f"Publishing with source_id: {args.source_id}")
        logger.info(f"Reading controller events from {args.device}...")
        button_subjects = ', '.join(sorted(set(BUTTON_MAP.values()) | set(BUTTON_SHIFT_MAP.values())))
        logger.info(f"Subjects: joystick_x, joystick_y, joystick_rz, joystick_z, {button_subjects}")

        event_count = 0
        
        try:
            while not shutdown_requested:
                # Read joystick event
                event = read_joystick_event(js_device)
                
                if event:
                    timestamp, value, event_type, number = event
                    event_count += 1
                    
                    # Handle the event
                    handle_joystick_event(timestamp, value, event_type, number, session, args)
                else:
                    # Small sleep to avoid busy waiting when no data
                    time.sleep(0.001)  # 1ms sleep

        except KeyboardInterrupt:
            logger.info("Interrupted by user")
        except Exception as e:
            logger.error(f"Error: {e}")
            import traceback
            logger.error(traceback.format_exc())
        finally:
            js_device.close()
            logger.info(f"Processed {event_count} events")
            logger.info("Joystick device closed")


if __name__ == "__main__":
    main()
